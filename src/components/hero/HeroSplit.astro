---
import site from "../../data/site";
const { hero, primaryCta, secondaryCta, copy, businessName } = site;
---

<section class="relative overflow-hidden bg-surface">
  <div class="container-page grid gap-12 py-16 md:grid-cols-12 md:items-center md:py-24">
    <div class="md:col-span-7 md:pr-6">
      {hero.eyebrow && <span class="eyebrow mb-4">{hero.eyebrow}</span>}
      <h1 class="text-balance font-heading text-4xl font-semibold leading-[1.05] md:text-6xl">
        {hero.headline}
      </h1>
      <p class="mt-6 max-w-xl text-pretty text-lg text-muted md:text-xl">
        {hero.sub}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={primaryCta.href} class="btn-primary">{primaryCta.label}</a>
        {secondaryCta && <a href={secondaryCta.href} class="btn-ghost">{secondaryCta.label}</a>}
      </div>
      {hero.badges && hero.badges.length > 0 && (
        <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted">
          {hero.badges.map((b) => (
            <li class="flex items-center gap-2">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
              {b}
            </li>
          ))}
        </ul>
      )}
    </div>
    <div class="md:col-span-5">
      <div class="relative aspect-[4/5] overflow-hidden rounded-card bg-soft shadow-2xl shadow-ink/10">
        {hero.imageUrl ? (
          <img src={hero.imageUrl} alt={businessName} class="absolute inset-0 h-full w-full object-cover" />
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-primary/40 via-accent/20 to-soft"></div>
        )}
        <div class="absolute inset-x-4 bottom-4 rounded-2xl bg-surface/95 p-4 text-xs text-muted shadow-lg backdrop-blur">
          <div class="flex items-center gap-2 font-medium text-ink">
            <span class="inline-block h-2 w-2 rounded-full bg-accent"></span>
            {copy.contactUs}
          </div>
          <div class="mt-1">{site.contact.whatsappLabel ?? site.contact.phone ?? site.contact.email ?? site.domain}</div>
        </div>
      </div>
    </div>
  </div>
</section>
