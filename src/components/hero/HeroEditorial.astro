---
import site from "../../data/site";
const { hero, primaryCta, secondaryCta, businessName } = site;
const hasBadges = hero.badges && hero.badges.length > 0;
---

<section class="bg-surface">
  <div class="container-page py-20 md:py-28">
    <div class="grid gap-10 md:grid-cols-12 md:items-end">
      <div class="md:col-span-7">
        {hero.eyebrow && <span class="eyebrow mb-6 block">{hero.eyebrow}</span>}
        <h1 class="font-heading text-[2.75rem] font-semibold leading-[0.95] tracking-tight md:text-[5.5rem]">
          {hero.headline}
        </h1>
      </div>
      <div class="md:col-span-5 md:pl-8">
        <p class="text-pretty border-l border-accent pl-6 text-base italic text-muted md:text-lg">
          {hero.sub}
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={primaryCta.href} class="btn-primary">{primaryCta.label}</a>
          {secondaryCta && <a href={secondaryCta.href} class="btn-ghost">{secondaryCta.label}</a>}
        </div>
      </div>
    </div>

    {hasBadges && (
      <ul class="mt-14 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-line pt-6 text-sm uppercase tracking-[0.16em] text-muted">
        {hero.badges!.map((b) => (
          <li class="flex items-center gap-2">
            <span class="inline-block h-1 w-1 rounded-full bg-accent"></span>
            {b}
          </li>
        ))}
      </ul>
    )}

    {hero.imageUrl && (
      <figure class="mt-16">
        <img src={hero.imageUrl} alt={businessName} class="aspect-[16/9] w-full rounded-card object-cover" />
        <figcaption class="mt-3 text-xs uppercase tracking-[0.18em] text-muted">{businessName}</figcaption>
      </figure>
    )}
  </div>
</section>
