---
import site from "../../data/site";
const { hero, primaryCta, secondaryCta, businessName, contact } = site;
---

<section class="relative bg-soft text-ink">
  <div class="container-page border-y-2 border-ink py-2 text-[11px] font-mono uppercase tracking-widest">
    <div class="flex flex-wrap justify-between gap-x-8 gap-y-1">
      <span>{businessName}</span>
      <span>est.</span>
      <span>{site.domain}</span>
      <span>{contact.phone ?? contact.email ?? ""}</span>
    </div>
  </div>

  <div class="container-page py-14 md:py-20">
    {hero.eyebrow && (
      <span class="inline-block border-2 border-ink bg-surface px-3 py-1 text-xs font-mono uppercase tracking-widest">
        {hero.eyebrow}
      </span>
    )}
    <h1 class="mt-8 font-heading text-[3.5rem] font-bold leading-[0.9] tracking-tight md:text-[8rem]">
      {hero.headline}
    </h1>
    <div class="mt-12 grid gap-8 border-t-2 border-ink pt-8 md:grid-cols-12">
      <p class="text-pretty md:col-span-7 text-lg md:text-xl">
        {hero.sub}
      </p>
      <div class="flex flex-wrap items-start gap-3 md:col-span-5 md:justify-end">
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center border-2 border-ink bg-ink px-6 py-3 font-mono text-sm uppercase tracking-widest text-surface hover:bg-primary hover:text-primary-fg"
        >
          {primaryCta.label}
        </a>
        {secondaryCta && (
          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center border-2 border-ink bg-surface px-6 py-3 font-mono text-sm uppercase tracking-widest text-ink hover:bg-ink hover:text-surface"
          >
            {secondaryCta.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
