---
import site from "../../data/site";
const { businessName, contact, social } = site;
const year = new Date().getFullYear();
const socialEntries = Object.entries(social).filter(([, v]) => Boolean(v)) as [string, string][];
---

<footer class="border-t border-line bg-surface py-10">
  <div class="container-page flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-muted">© {year} {businessName}. Todos os direitos reservados.</p>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
      {contact.email && <a href={`mailto:${contact.email}`} class="hover:text-ink">{contact.email}</a>}
      {contact.phone && <a href={`tel:${contact.phone.replace(/\s+/g, "")}`} class="hover:text-ink">{contact.phone}</a>}
      {socialEntries.map(([k, v]) => <a href={v} class="capitalize hover:text-ink">{k}</a>)}
    </div>
  </div>
</footer>
