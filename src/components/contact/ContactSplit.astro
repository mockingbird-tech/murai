---
import site from "../../data/site";
const { contact, primaryCta, copy, businessName } = site;
const phoneTel = contact.phone ? `tel:${contact.phone.replace(/\s+/g, "")}` : null;
---

<section id="contact" class="bg-soft py-20 md:py-28">
  <div class="container-page grid gap-12 md:grid-cols-12 md:items-start">
    <div class="md:col-span-5">
      <span class="eyebrow mb-4 block">{copy.sectionContact}</span>
      <h2 class="text-balance font-heading text-3xl font-semibold md:text-5xl">
        Vamos conversar.
      </h2>
      <p class="mt-4 text-base text-muted md:text-lg">
        {site.ctaSection.sub ?? "Resposta no mesmo dia, sem formulário gigante."}
      </p>
      <a href={primaryCta.href} class="btn-primary mt-8">{primaryCta.label}</a>
    </div>

    <dl class="md:col-span-7 grid gap-4 sm:grid-cols-2">
      {contact.whatsappHref && (
        <a href={contact.whatsappHref} class="rounded-card border border-line bg-surface p-6 transition hover:border-primary/40">
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">WhatsApp</dt>
          <dd class="mt-2 font-heading text-lg font-semibold">{contact.whatsappLabel ?? contact.phone ?? primaryCta.label}</dd>
        </a>
      )}
      {phoneTel && (
        <a href={phoneTel} class="rounded-card border border-line bg-surface p-6 transition hover:border-primary/40">
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Telefone</dt>
          <dd class="mt-2 font-heading text-lg font-semibold">{contact.phone}</dd>
        </a>
      )}
      {contact.email && (
        <a href={`mailto:${contact.email}`} class="rounded-card border border-line bg-surface p-6 transition hover:border-primary/40">
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">E-mail</dt>
          <dd class="mt-2 break-all font-heading text-lg font-semibold">{contact.email}</dd>
        </a>
      )}
      {contact.address && (
        <a
          href={contact.mapsUrl ?? "#"}
          class="rounded-card border border-line bg-surface p-6 transition hover:border-primary/40"
        >
          <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Endereço</dt>
          <dd class="mt-2 font-heading text-base font-semibold leading-snug">{contact.address}</dd>
          {contact.hours && <p class="mt-2 text-xs text-muted">{contact.hours}</p>}
        </a>
      )}
    </dl>
  </div>
</section>
