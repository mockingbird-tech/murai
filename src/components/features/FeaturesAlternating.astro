---
import site from "../../data/site";
const { features } = site;
---

<section id="features" class="bg-surface py-20 md:py-28">
  <div class="container-page">
    <div class="max-w-3xl">
      {features.eyebrow && <span class="eyebrow mb-4 block">{features.eyebrow}</span>}
      {features.title && (
        <h2 class="text-balance font-heading text-3xl font-semibold md:text-5xl">{features.title}</h2>
      )}
      {features.intro && <p class="mt-4 text-lg text-muted">{features.intro}</p>}
    </div>

    <div class="mt-14 space-y-16">
      {features.items.map((f, i) => (
        <article class={`grid items-center gap-10 md:grid-cols-12 ${i % 2 === 1 ? "md:[&>*:first-child]:order-2" : ""}`}>
          <div class="md:col-span-6">
            <div class="aspect-[5/4] overflow-hidden rounded-card bg-gradient-to-br from-primary/20 via-soft to-accent/20"></div>
          </div>
          <div class="md:col-span-6">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent/15 font-heading text-sm font-semibold text-accent">
              {i + 1}
            </span>
            <h3 class="mt-4 font-heading text-2xl font-semibold md:text-3xl">{f.title}</h3>
            <p class="mt-3 text-pretty text-base text-muted md:text-lg">{f.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
